# Supabase — copy to .env.local and fill in real values (never commit .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only. Used for privileged admin operations (e.g. creating accounts).
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (notifications). Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Shared secret guarding the /api/cron/* reminder routes. Use the same value in
# the pg_cron jobs (migration 0015). Any random string.
CRON_SECRET=your-random-cron-secret
